-- View everything
SELECT * FROM Ecommerce_Sales_Data_2024_2025;
-- View only specific columns
SELECT customer_name, product_name, sales FROM Ecommerce_Sales_Data_2024_2025;

2. WHERE — filter rows by a condition:
SELECT * FROM Ecommerce_Sales_Data_2024_2025
WHERE region = 'North';
-- Numeric condition
SELECT * FROM Ecommerce_Sales_Data_2024_2025
WHERE sales &gt; 50000;
-- Combine conditions
SELECT * FROM Ecommerce_Sales_Data_2024_2025
WHERE region = 'North' AND category = 'Electronics';

3. ORDER BY — sort your results:
SELECT customer_name, sales FROM Ecommerce_Sales_Data_2024_2025
ORDER BY sales DESC;
-- Ascending (smallest first) — default, no need to write ASC
SELECT customer_name, sales FROM Ecommerce_Sales_Data_2024_2025
ORDER BY sales ASC;

4. LIMIT — restrict how many rows come back:
SELECT customer_name, sales FROM Ecommerce_Sales_Data_2024_2025
ORDER BY sales DESC
LIMIT 10;

5. GROUP BY — aggregate/summarize data:
SELECT category, SUM(sales) AS total_sales
FROM Ecommerce_Sales_Data_2024_2025
GROUP BY category;
-- Multiple aggregates at once
SELECT category,
       SUM(sales) AS total_sales,
       AVG(profit) AS avg_profit,
       COUNT(order_id) AS num_orders
FROM Ecommerce_Sales_Data_2024_2025
GROUP BY category;

6. HAVING — filter groups (after GROUP BY):
SELECT category, SUM(sales) AS total_sales
FROM Ecommerce_Sales_Data_2024_2025
GROUP BY category
HAVING total_sales &gt; 500000;

7. JOIN — combine data from two tables:
CREATE TABLE region_managers (
    region TEXT,
    manager_name TEXT
);
INSERT INTO region_managers VALUES
('North', 'Ravi Shah'),
('South', 'Priya Nair'),
('East', 'Amit Sen'),
('West', 'Neha Gupta');

SELECT s.customer_name, s.region, s.sales, r.manager_name
FROM Ecommerce_Sales_Data_2024_2025 s
JOIN region_managers r ON s.region = r.region;
</sql><sql name="queries.sql1">1. Subqueries:
-- Find orders with sales above the overall average
SELECT customer_name, product_name, sales
FROM Ecommerce_Sales_Data_2024_2025
WHERE sales &gt; (SELECT AVG(sales) FROM Ecommerce_Sales_Data_2024_2025);

-- Find the single highest-profit order per region using a subquery
SELECT region, product_name, profit
FROM Ecommerce_Sales_Data_2024_2025 e
WHERE profit = (
    SELECT MAX(profit)
    FROM Ecommerce_Sales_Data_2024_2025
    WHERE region = e.region
);


2. CTEs (WITH clause):
WITH category_summary AS (
    SELECT category, SUM(sales) AS total_sales, SUM(profit) AS total_profit
    FROM Ecommerce_Sales_Data_2024_2025
    GROUP BY category
)
SELECT * FROM category_summary
WHERE total_profit &gt; 100000
ORDER BY total_profit DESC;

3. Window functions:
-- RANK: rank products by sales within each category
SELECT category, product_name, sales,
       RANK() OVER (PARTITION BY category ORDER BY sales DESC) AS rank_in_category
FROM Ecommerce_Sales_Data_2024_2025;
-- ROW_NUMBER: simple sequential numbering
SELECT customer_name, sales,
       ROW_NUMBER() OVER (ORDER BY sales DESC) AS row_num
FROM Ecommerce_Sales_Data_2024_2025;
-- LAG/LEAD: compare each row to the previous/next one (useful for trends)
SELECT order_date, sales,
       LAG(sales) OVER (ORDER BY order_date) AS previous_order_sales,
       LEAD(sales) OVER (ORDER BY order_date) AS next_order_sales
FROM Ecommerce_Sales_Data_2024_2025;

4. Views — save a query for reuse:
CREATE VIEW top_products AS
SELECT product_name, SUM(sales) AS total_sales
FROM Ecommerce_Sales_Data_2024_2025
GROUP BY product_name
ORDER BY total_sales DESC;
SELECT * FROM top_products LIMIT 5;


</sql><current_tab id="1"/></tab_sql></sqlb_project>
